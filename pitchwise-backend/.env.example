# Environment variables for PitchWise Backend
# Copy this file to .env and update with your actual values

# Database Configuration
DATABASE_URL=mysql+pymysql://root:password@localhost/pitchwise_db

# JWT Secret Key (Generate a secure random key for production)
SECRET_KEY=your-super-secret-key-change-this-in-production-use-openssl-rand-hex-32

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# File Upload Settings
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE=52428800
